# converter サービスの環境変数

# サーバーポート
PORT=3001

# Supabase 接続情報（service_role key はサーバーサイドのみ使用）
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# callback 認証用の共有シークレット（apps/web と同じ値を設定）
CONVERTER_API_KEY=your-shared-secret-here

# IfcConvert CLI のパス（Docker 内では /usr/local/bin/IfcConvert）
IFCCONVERT_PATH=/usr/local/bin/IfcConvert
